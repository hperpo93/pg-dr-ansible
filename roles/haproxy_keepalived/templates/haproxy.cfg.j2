global
    log /dev/log local0
    log /dev/log local1 notice
    chroot /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 level admin expose-fd listeners
    stats timeout 30s
    user haproxy
    group haproxy
    daemon
    maxconn 4096

defaults
    log global
    mode tcp
    option tcplog
    option dontlognull
    timeout connect 5s
    timeout client 3600s
    timeout server 3600s
    retries 3

# ---------------------------------------------------------------------------
# Read-Write frontend — routes to Patroni primary only
# HAProxy checks /master on Patroni API (port 8008); only primary returns 200
# ---------------------------------------------------------------------------
frontend p_rw_frontend
    bind *:{{ haproxy_rw_port }}
    mode tcp
    timeout client 3600s
    default_backend p_rw_backend

# ---------------------------------------------------------------------------
# Read-Only frontend — routes to replicas
# HAProxy checks /replica on Patroni API; only replicas return 200
# ---------------------------------------------------------------------------
frontend p_ro_frontend
    bind *:{{ haproxy_ro_port }}
    mode tcp
    timeout client 3600s
    default_backend p_ro_backend

# ---------------------------------------------------------------------------
# Read-Write backend — primary only
# ---------------------------------------------------------------------------
backend p_rw_backend
    mode tcp
    option httpchk GET /master
    option tcpka
    http-check expect status 200
    balance roundrobin
    timeout connect 5s
    timeout server 3600s
{% for host in groups['pg_nodes'] %}
    server {{ host }} {{ hostvars[host]['ansible_default_ipv4']['address'] }}:{{ pg_port }} check port {{ patroni_api_port }} check-ssl verify none
{% endfor %}

# ---------------------------------------------------------------------------
# Read-Only backend — replicas only
# ---------------------------------------------------------------------------
backend p_ro_backend
    mode tcp
    option httpchk GET /replica
    option tcpka
    http-check expect status 200
    balance roundrobin
    timeout connect 5s
    timeout server 3600s
{% for host in groups['pg_nodes'] %}
    server {{ host }} {{ hostvars[host]['ansible_default_ipv4']['address'] }}:{{ pg_port }} check port {{ patroni_api_port }} check-ssl verify none
{% endfor %}
