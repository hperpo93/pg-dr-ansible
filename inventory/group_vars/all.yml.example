# =============================================================================
# All Variables — EXAMPLE FILE
# Copy to all.yml and fill in the values marked CHANGE_ME.
#
#   cp inventory/group_vars/all.yml.example inventory/group_vars/all.yml
#
# Everything else is derived automatically from inventory at runtime —
# no IPs or hostnames are hardcoded here.
# =============================================================================

# --- PostgreSQL ---------------------------------------------------------------
pg_version: "18"
pg_user: postgres
pg_group: postgres
pg_port: 5432
pg_data_dir: /var/lib/postgresql/data
pg_ssl_dir: /var/lib/postgresql/ssl
pg_bin_dir: "/usr/lib/postgresql/{{ pg_version }}/bin"

pg_superuser: postgres
pg_superuser_password: "CHANGE_ME"

pg_replication_user: replicator
pg_replication_password: "CHANGE_ME"

pg_parameters:
  max_connections: 100
  shared_buffers: 256MB

# --- etcd ---------------------------------------------------------------------
etcd_version: "3.6.7"
etcd_download_url: "https://github.com/etcd-io/etcd/releases/download"
etcd_install_dir: /usr/local/src/etcd
etcd_bin_dir: /usr/local/bin
etcd_data_dir: /var/lib/etcd
etcd_conf_dir: /etc/etcd
etcd_ssl_dir: /etc/etcd/ssl
etcd_user: etcd
etcd_group: etcd
etcd_client_port: 2379
etcd_peer_port: 2380
etcd_cluster_token: etcd-cluster

# etcd_initial_cluster and etcd_endpoints_all are built dynamically from
# inventory in the etcd role and etcd.env.j2 template — do not set them here.

# --- Certs (etcd CA — generated on control node, distributed) ----------------
cert_local_dir: "{{ playbook_dir }}/../certs"
etcd_cert_days: 7300
etcd_ca_subj: "/CN=etcd-ca"
pg_cert_days: 7300

# --- Patroni ------------------------------------------------------------------
patroni_scope: postgresql-cluster                       # CHANGE if needed
patroni_namespace: /service/
patroni_conf_dir: /etc/patroni
patroni_conf_file: /etc/patroni/config.yml
patroni_api_port: 8008
patroni_log_dir: /var/log/patroni

patroni_dcs:
  ttl: 30
  loop_wait: 10
  retry_timeout: 10
  maximum_lag_on_failover: 1048576

# pg_hba replication entries are built dynamically from inventory in the
# patroni.config.yml.j2 template — do not hardcode IPs here.
# Static entries that don't depend on node IPs:
patroni_pg_hba_static:
  - "local all postgres peer"
  - "host all all 127.0.0.1/32 trust"   # Patroni heartbeat / local tools
  - "host all all ::1/128 trust"         # Patroni heartbeat via IPv6 loopback
  - "host all all 0.0.0.0/0 md5"
  - "hostssl replication replicator 127.0.0.1/32 md5"
  - "hostssl all all 127.0.0.1/32 md5"
  - "hostssl all all 0.0.0.0/0 md5"

# --- HAProxy ------------------------------------------------------------------
haproxy_rw_port: 5432
haproxy_ro_port: 5433
haproxy_cfg: /etc/haproxy/haproxy.cfg

# haproxy_pg_servers is built dynamically from the [pg_nodes] inventory group
# in haproxy.cfg.j2 — do not hardcode server IPs here.

# --- Keepalived ---------------------------------------------------------------
keepalived_vip: 192.168.100.204                        # CHANGE — your VIP
keepalived_interface: eth0                             # CHANGE if needed
keepalived_router_id: 51
keepalived_advert_int: 1
keepalived_check_script: /etc/keepalived/check_haproxy.sh

# --- pgBackRest ---------------------------------------------------------------
pgbackrest_stanza: postgresql-cluster
pgbackrest_repo_host: backup-server                    # CHANGE — backup server hostname
pgbackrest_repo_host_user: postgres
pgbackrest_repo_path: /backups
pgbackrest_conf: /etc/pgbackrest/pgbackrest.conf
pgbackrest_log_dir: /var/log/pgbackrest
pgbackrest_jobs: 4
pgbackrest_restore_type: default                       # default | time | name | lsn
pgbackrest_restore_set: ""             # optional: specific backup label e.g. 20260331-114616F_20260331-120257I
pgbackrest_restore_target: ""
pgbackrest_restore_target_action: promote

# --- Patching notifications ---------------------------------------------------
patch_notify_contacts:
  - name: CHANGE_ME
    email: "CHANGE_ME@example.com"
  - name: CHANGE_ME
    email: "CHANGE_ME@example.com"

patch_notify_from:   "dba-noreply@example.com"    # CHANGE
patch_smtp_host:     "localhost"
patch_smtp_port:     25
patch_slack_webhook: ""                                # optional
patch_window_start:  "<YYYY-MM-DD HH:MM>"              # CHANGE before each patch
patch_window_end:    "<YYYY-MM-DD HH:MM>"              # CHANGE before each patch
patch_replica_rejoin_timeout: 120
patch_primary_rejoin_timeout: 120
patch_dry_run: false

# --- Reindexing ---------------------------------------------------------------
reindex_bloat_threshold_pct: 20
reindex_min_table_size_mb: 10
reindex_target_databases: []
reindex_metric_log: /var/log/postgresql/reindex_metrics.log
reindex_dry_run: false
reindex_lock_timeout: "5min"
reindex_include_system: false

# --- Safety -------------------------------------------------------------------
min_free_disk_gb: 20

